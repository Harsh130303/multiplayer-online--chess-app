# ♟️ Chess Platform Production Environment Configuration
# Copy this file to a new file named '.env' on your production server.

# PostgreSQL Connection Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=choose_a_strong_password_here
POSTGRES_DB=chess

# FastAPI Security Keys (Generate a safe 32-character hexadecimal secret key)
# You can generate a random key in terminal via: openssl rand -hex 32
SECRET_KEY=generate_a_secure_hex_key_here
